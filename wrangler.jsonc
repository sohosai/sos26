{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "sos26",
  "compatibility_date": "2026-03-04",
  "assets": {
    "directory": "./apps/web/dist"
  },
  "env": {
    "dev": {
      "name": "sos26-dev",
      "routes": [
        {
          "pattern": "dev.sos26.sohosai.com/*",
          "custom_domain": true
        }
      ]
    }
  }
}
